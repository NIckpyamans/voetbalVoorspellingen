{
  "version": 2,
  "framework": "vite",
  "ignoreCommand": "node scripts/vercel-ignore-build.js",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/matches",   "destination": "/api/Matches"  },
    { "source": "/api/analyze",   "destination": "/api/analyze"  },
    { "source": "/api/standings", "destination": "/api/standings"},
    { "source": "/api/logo",      "destination": "/api/logo"     },
    { "source": "/api/(.*)",      "destination": "/api/$1"       },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
